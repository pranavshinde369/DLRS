{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/dlrs/schemas/manifest.schema.json",
  "title": "DLRS Human Record Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_id",
    "visibility",
    "subject",
    "rights",
    "consent",
    "artifacts",
    "deletion_policy",
    "inheritance_policy",
    "security",
    "review",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.2\\.\\d+$"
    },
    "record_id": {
      "type": "string",
      "pattern": "^dlrs_[a-zA-Z0-9_-]{8,}$"
    },
    "display_slug": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "team",
        "public_indexed",
        "public_unlisted"
      ]
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "display_name",
        "locale",
        "residency_region",
        "is_minor",
        "status"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "self",
            "authorized_agent",
            "estate_authorized",
            "public_data_only"
          ]
        },
        "display_name": {
          "type": "string"
        },
        "legal_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "locale": {
          "type": "string"
        },
        "residency_region": {
          "type": "string"
        },
        "is_minor": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "living",
            "deceased",
            "unknown",
            "incapacitated"
          ]
        }
      },
      "additionalProperties": true
    },
    "rights": {
      "type": "object",
      "required": [
        "uploader_role",
        "rights_basis",
        "evidence_refs",
        "allow_public_listing",
        "allow_commercial_use",
        "allow_model_finetune",
        "allow_voice_clone",
        "allow_avatar_clone",
        "cross_border_transfer_basis"
      ],
      "properties": {
        "uploader_role": {
          "type": "string"
        },
        "rights_basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_public_listing": {
          "type": "boolean"
        },
        "allow_commercial_use": {
          "type": "boolean"
        },
        "allow_model_finetune": {
          "type": "boolean"
        },
        "allow_voice_clone": {
          "type": "boolean"
        },
        "allow_avatar_clone": {
          "type": "boolean"
        },
        "allow_research_use": {
          "type": "boolean"
        },
        "cross_border_transfer_basis": {
          "type": "string",
          "enum": [
            "none",
            "consent_only",
            "standard_contract",
            "certification",
            "security_assessment",
            "other_lawful_basis"
          ]
        },
        "cross_border_transfer_status": {
          "type": "string",
          "enum": [
            "not_needed",
            "pending",
            "approved",
            "blocked"
          ]
        }
      },
      "additionalProperties": true
    },
    "consent": {
      "type": "object",
      "required": [
        "captured_at",
        "withdrawal_endpoint",
        "separate_biometric_consent"
      ],
      "properties": {
        "captured_at": {
          "type": "string"
        },
        "withdrawal_endpoint": {
          "type": "string",
          "minLength": 3
        },
        "separate_biometric_consent": {
          "type": "boolean"
        },
        "guardian_consent": {
          "type": "boolean"
        },
        "consent_version": {
          "type": "string"
        },
        "allowed_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "type",
          "format",
          "storage_uri",
          "checksum",
          "region",
          "sensitivity"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "storage_uri": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "sensitivity": {
            "type": "string",
            "enum": [
              "S0_PUBLIC",
              "S1_INTERNAL",
              "S2_SENSITIVE",
              "S3_BIOMETRIC",
              "S4_RESTRICTED"
            ]
          },
          "contains_sensitive_data": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "deletion_policy": {
      "type": "object",
      "required": [
        "allow_delete",
        "allow_export",
        "withdrawal_effect"
      ],
      "properties": {
        "allow_delete": {
          "type": "boolean"
        },
        "allow_export": {
          "type": "boolean"
        },
        "withdrawal_effect": {
          "type": "string",
          "enum": [
            "freeze_runtime_then_delete",
            "freeze_runtime_keep_archive",
            "delete_all_nonlegal_holds"
          ]
        },
        "legal_hold": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "inheritance_policy": {
      "type": "object",
      "required": [
        "policy_ref",
        "default_action_on_death",
        "executor_contact_ref"
      ],
      "properties": {
        "policy_ref": {
          "type": "string"
        },
        "default_action_on_death": {
          "type": "string",
          "enum": [
            "freeze",
            "delete",
            "memorial_private",
            "memorial_public_review_required"
          ]
        },
        "executor_contact_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "security": {
      "type": "object",
      "required": [
        "primary_region",
        "encryption_at_rest",
        "watermark_policy",
        "c2pa_enabled"
      ],
      "properties": {
        "primary_region": {
          "type": "string"
        },
        "replication_regions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "encryption_at_rest": {
          "type": "boolean"
        },
        "kms_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "watermark_policy": {
          "type": "string"
        },
        "c2pa_enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "verified_consent_badge",
        "public_data_only_badge",
        "risk_level"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "submitted",
            "blocked",
            "approved_private",
            "approved_public"
          ]
        },
        "verified_consent_badge": {
          "type": "boolean"
        },
        "public_data_only_badge": {
          "type": "boolean"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reviewer_notes_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "created_at",
        "last_modified_at",
        "change_log_hash"
      ],
      "properties": {
        "created_at": {
          "type": "string"
        },
        "last_modified_at": {
          "type": "string"
        },
        "change_log_hash": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
